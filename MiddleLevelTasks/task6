
// Что значит каждая функция и
// Как будет собираться докер образ?
// Какие команды для сборки и запуска контейнера?


FROM golang:1.17 AS builder -  скачиваем версию го и задаем обращение

WORKDIR /app  - создаем рабочую директорию

COPY go.mod go.sum ./  -  копируем туда файлы с зависимостями

RUN go mod download  -  скачиваем зависимости

COPY . .  -  теперь копируем весь код

RUN go build -o myapp .  -  компилируем в файл с именем myapp

FROM alpine:latest  -  alpine это дистрибутив линукс, latest это версия

WORKDIR /root/  -  устанавливаем рабочую директорию

COPY --from=builder /app/myapp .  -  забираем только один скомпилированный файл my app из первого этапа

CMD ["./myapp"]  -  инструкция, которая говорит контейнеру, какой процесс запустить при старте

Сборка происходит так: Docker создает окружение со всеми инструментами разработки Go, скачивает библиотеки и превращает код в исполняемый файл.
Потом Docker берет чистый лист (Alpine), кладет туда готовый файл и «выбрасывает» всё лишнее из первого шага

Для сборки и запуска нужно использовать команды:
дать образу имя - docker build -t my-app .
запустить контейнер docker run -d --name my-running-app my-app